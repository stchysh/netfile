{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetFile",
  "version": "0.1.0",
  "identifier": "com.netfile.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "ui/dist"
  },
  "bundle": {
    "active": true,
