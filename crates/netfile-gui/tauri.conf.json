{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetFile",
  "version": "0.1.0",
  "identifier": "com.netfile.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "NetFile",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fileDropEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  }
}
