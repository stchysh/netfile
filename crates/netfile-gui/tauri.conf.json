{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetFile",
  "version": "0.1.0",
  "identifier": "com.netfile.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "NetFile",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "dialog:allow-message",
            "shell:allow-open"
          ]
        }
      ]
    }
  }
}
